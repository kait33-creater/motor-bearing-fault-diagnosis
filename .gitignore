# =========================
# Python 缓存文件
# =========================
__pycache__/
*.py[cod]
*.pyo
*.pyd

# =========================
# 虚拟环境
# =========================
venv/
.venv/
env/
ENV/

# =========================
# Jupyter Notebook 缓存
# =========================
.ipynb_checkpoints/

# =========================
# VS Code / 编辑器配置
# =========================
.vscode/
.idea/

# =========================
# 系统文件
# =========================
.DS_Store
Thumbs.db

# =========================
# 日志文件
# =========================
*.log

# =========================
# 数据文件
# 原始数据和处理中间数据一般不上传
# =========================
data/raw/*
data/processed/*

# 但保留文件夹结构
!data/raw/.gitkeep
!data/processed/.gitkeep

# sample 文件夹可以放小样例数据，建议保留
# data/sample/ 不忽略

# =========================
# 输出结果
# 图表、报告、模型文件通常由代码生成，不建议全部提交
# =========================
outputs/figures/*
outputs/reports/*
outputs/models/*

# 但保留文件夹结构
!outputs/figures/.gitkeep
!outputs/reports/.gitkeep
!outputs/models/.gitkeep

# =========================
# 机器学习模型文件
# =========================
*.pkl
*.joblib
*.model
*.h5

# =========================
# 环境变量文件
# =========================
.env
